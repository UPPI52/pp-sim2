{
  "project_overview": {
    "name": "pp-sim2",
    "description": "Puyo Puyo Simulator - Web-based game with online multiplayer, AI, and editing capabilities",
    "repository": "UPPI52/pp-sim2",
    "language_composition": {
      "JavaScript": "84.8%",
      "CSS": "8.8%",
      "HTML": "6.4%"
    },
    "type": "Web Application (Vanilla JS)",
    "features": [
      "Game Simulation (Puyo Puyo)",
      "Online Multiplayer (PeerJS)",
      "AI Opponent (Web Worker)",
      "Edit Mode (Stage Creation)",
      "Undo/Redo System",
      "PWA Support",
      "Mobile Controls"
    ]
  },
  "architecture": {
    "core_files": {
      "puyoSim.js": {
        "size_lines": 1703,
        "purpose": "Main game simulation engine",
        "responsibilities": [
          "Board management (6x14 grid)",
          "Piece mechanics (rotation, movement, gravity)",
          "Chain detection and scoring",
          "Garbage (ojama) handling",
          "History (Undo/Redo)",
          "Game state management",
          "UI rendering",
          "Edit mode"
        ]
      },
      "online.js": {
        "size_lines": 798,
        "purpose": "Online multiplayer via PeerJS",
        "responsibilities": [
          "Peer connection management",
          "Match proposal and acceptance",
          "Board state synchronization",
          "Garbage exchange",
          "Rematch system",
          "Online UI overlays"
        ]
      },
      "puyoAI.js": {
        "size_lines": 424,
        "purpose": "AI controller using Web Workers",
        "responsibilities": [
          "Worker lifecycle management",
          "Game state packing for AI",
          "Move request/response handling",
          "Auto-play loop",
          "UI status updates"
        ]
      },
      "puyo-ai-worker.js": {
        "purpose": "AI computation (Worker thread)",
        "note": "Main AI algorithm file"
      },
      "puyo-ai-worker-gtr.js": {
        "purpose": "Alternative AI variant",
        "note": "GTR-based AI algorithm"
      },
      "puyoAI_wasm.mjs": {
        "purpose": "WebAssembly AI module",
        "note": "WASM wrapper for performance"
      }
    }
  },
  "core_mechanics": {
    "board_structure": {
      "width": 6,
      "height": 14,
      "hidden_rows": 2,
      "visible_rows": 12,
      "colors": {
        "EMPTY": 0,
        "RED": 1,
        "BLUE": 2,
        "GREEN": 3,
        "YELLOW": 4,
        "GARBAGE": 5
      }
    },
    "scoring_system": {
      "base_formula": "10 × (number of puyos cleared) × bonus_multiplier",
      "bonus_components": {
        "chain_bonus": "Increases with consecutive chains",
        "group_bonus": "Based on group size (4+ puyos)",
        "color_bonus": "Based on number of colors in chain"
      },
      "all_clear_bonus": 2100,
      "nuisance_conversion": "1 ojama = 70 points"
    },
    "chain_detection": {
      "algorithm": "Depth-first search (DFS) connected component",
      "minimum_group_size": 4,
      "clear_condition": "4 or more connected puyos of same color",
      "garbage_clearing": "Adjacent to cleared puyos"
    },
    "gravity_mechanics": {
      "simulation": "Puyos fall until blocked",
      "soft_drop": "Manual single-row descent",
      "hard_drop": "Instant placement to bottom",
      "gravity_wait_time": "300ms (configurable)",
      "chain_wait_time": "300ms (configurable)"
    }
  },
  "game_flow": {
    "states": [
      "playing - Active piece control",
      "chaining - Chain detection and scoring",
      "gameover - Game ended",
      "editing - Stage editor mode",
      "setting - Configuration menu"
    ],
    "turn_sequence": [
      "Piece generation (from NEXT queue)",
      "Player input (movement, rotation, placement)",
      "Gravity application",
      "Chain detection",
      "Scoring & display",
      "Garbage application",
      "Game over check"
    ]
  },
  "next_queue_system": {
    "capacity": 50,
    "visible_count": 2,
    "balancing": {
      "batch_size": 128,
      "strategy": "Color-balanced batches (4 colors)",
      "colors_per_batch": 64,
      "constraint": "Avoid 4 unique colors in first 2 pairs"
    },
    "implementation": "Ring buffer with pre-generated batches"
  },
  "ojama_system": {
    "incoming_ojama": "Queue waiting to drop",
    "outgoing_ojama": "Sent from own chains",
    "conversion": "Attack score → ojama count (÷70)",
    "cancellation": "Incoming vs Outgoing offset",
    "drop_rate": "Maximum 30 ojama per turn",
    "placement": "Random column order"
  },
  "ai_integration": {
    "architecture": "Web Worker-based",
    "state_packing": {
      "board": "Flattened Uint8Array (6×14)",
      "pieces": "Current + NEXT1 + NEXT2",
      "pending_ojama": "Integer count"
