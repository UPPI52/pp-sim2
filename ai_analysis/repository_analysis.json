    "algorithms": [
      {
        "name": "puyo-ai-worker.js",
        "type": "Main AI",
        "technique": "Beam search with future seed evaluation"
      },
      {
        "name": "puyo-ai-worker-gtr.js",
        "type": "Variant",
        "technique": "GTR-based evaluation"
      },
      {
        "name": "puyoAI_wasm.mjs",
        "type": "Performance",
        "technique": "WebAssembly compilation"
      }
    ],
    "move_output": {
      "x": "Column position (0-5)",
      "y": "Row position (0-13)",
      "rotation": "Piece orientation (0-3)"
    },
    "performance_targets": {
      "think_time_ms": 12000,
      "auto_tick_ms": 140,
      "ready_timeout_ms": 8000
    }
  },
  "online_multiplayer": {
    "protocol": "PeerJS (WebRTC)",
    "peer_server": "Default PeerJS signal server",
    "ice_servers": [
      "stun:stun.l.google.com:19302",
      "stun:stun1.l.google.com:19302",
      "stun:stun2.l.google.com:19302"
    ],
    "message_types": [
      {
        "type": "BOARD_UPDATE",
        "frequency": "100ms",
        "data": ["board", "currentPuyo", "gameState", "score", "chainCount", "ojamaPending"]
      },
      {
        "type": "OJAMA",
        "data": ["amount"]
      },
      {
        "type": "SYNC_NEXT",
        "data": ["nextPuyos"]
      },
      {
        "type": "PROPOSE_MATCH",
        "data": ["winTarget"]
      },
      {
        "type": "OPPONENT_LOST",
        "purpose": "Signal game over"
      }
    ],
    "match_system": {
      "win_target": "1-10 wins to win series",
      "series_format": "Best-of-N format"
    }
  },
  "data_persistence": {
    "stage_code": {
      "format": "Base64 encoded binary",
      "content": "Board state + 50 NEXT puyos",
      "encoding": "3-bit color values (packed binary)"
    },
    "history": {
      "max_size": 300,
      "contents": [
        "Board snapshot",
        "Next queue",
        "Queue index",
        "Score",
        "Chain count",
        "Pending ojama",
        "Current piece state"
      ]
